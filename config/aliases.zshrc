# SSH Agent Forwarding by default
alias ssh="ssh -A"

which htop > /dev/null \
  && alias top=htop

which docker > /dev/null \
  && alias d=docker

which kubectl > /dev/null \
  && alias k=kubectl

which exa > /dev/null \
  && alias ls=exa

which ccat > /dev/null \
  && alias cat=ccat

which lazygit > /dev/null \
  && alias g=lazygit

which nvim > /dev/null \
  && alias n=nvim

which terraform > /dev/null \
  && alias t=terraform